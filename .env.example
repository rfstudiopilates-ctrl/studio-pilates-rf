# ===========================================
# Studio Pilates RF - Variables de entorno
# ===========================================
# Copiar a backend/.env y frontend/.env según corresponda

# --- Backend (Railway / local) ---
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# MySQL (local o Railway)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=tu_password
DB_NAME=studio_pilates_rf

# JWT
JWT_ACCESS_SECRET=cambiar_por_secreto_largo_y_aleatorio_access
JWT_REFRESH_SECRET=cambiar_por_secreto_largo_y_aleatorio_refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Zona horaria
TZ=America/Argentina/Buenos_Aires

# --- Frontend (Vercel / local) ---
# VITE_API_URL=http://localhost:3001/api
# VITE_APP_NAME=Studio Pilates RF
