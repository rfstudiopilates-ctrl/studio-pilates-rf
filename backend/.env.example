NODE_ENV=development
PORT=3001
APP_URL=http://localhost:5173

# Uno o varios orígenes del frontend separados por coma
CORS_ORIGIN=http://localhost:5173

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=studio_pilates_rf

# En producción: ≥32 caracteres aleatorios, distintos entre sí (no uses estos valores)
JWT_ACCESS_SECRET=dev_access_secret_cambiar_en_produccion
JWT_REFRESH_SECRET=dev_refresh_secret_cambiar_en_produccion
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cross-site (Vercel + Railway): none + secure. Same-origin proxy: strict o lax
# AUTH_COOKIE_SAMESITE=none
# AUTH_COOKIE_SECURE=true

# Solo staging: permite arrancar con admin/cliente demo del init.sql
# ALLOW_DEMO_CREDENTIALS=false

TZ=America/Argentina/Buenos_Aires

# Push PWA (recomendado en producción — generar con: npm run generate:vapid -w backend)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@studiopilatesrf.com
